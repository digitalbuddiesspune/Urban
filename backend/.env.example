PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
NODE_ENV=production

# Comma-separated frontend URLs (no trailing slash)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://urban-usersite.onrender.com

# Seed credentials (local only — npm run seed)
SEED_ADMIN_EMAIL=admin@urbanease.com
SEED_ADMIN_PASSWORD=your_admin_password
SEED_VENDOR_EMAIL=vendor@urbanease.com
SEED_VENDOR_PASSWORD=your_vendor_password
