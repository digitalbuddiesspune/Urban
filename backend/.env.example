# Copy these to Render → Backend service → Environment (do NOT commit real secrets)

PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/urbanease?appName=urbaneaseDB
JWT_SECRET=use_a_long_random_secret_here
JWT_EXPIRE=30d
NODE_ENV=production

# Comma-separated frontend URLs (no trailing slash)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://urban-usersite.onrender.com,https://urban-vendorsite.onrender.com

# Optional — only for `npm run seed` on your machine
SEED_ADMIN_EMAIL=admin@urbanease.com
SEED_ADMIN_PASSWORD=your_admin_password
SEED_VENDOR_EMAIL=vendor@urbanease.com
SEED_VENDOR_PASSWORD=your_vendor_password
